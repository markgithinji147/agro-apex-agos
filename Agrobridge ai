<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgroApex OS - Advanced Master Prototype</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #050805;         /* Extreme Dark Emerald-Black */
            --panel-color: #111A11;      /* Agro-Glass Transparent Base */
            --neon-green: #00E676;       /* Neon Digital Lime */
            --predator-red: #FF1744;     /* Predator Red Alert */
            --text-main: #90A4AE;        /* Metallic Slate Gray */
            --border-color: #1a2e1a;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 0;
        }

        header {
            background-color: var(--panel-color);
            border-bottom: 2px solid var(--neon-green);
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0, 230, 118, 0.1);
        }

        .logo-area h1 {
            color: var(--neon-green);
            margin: 0;
            font-size: 26px;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(0, 230, 118, 0.5);
        }

        .patent-tag {
            font-size: 11px;
            color: var(--text-main);
            border: 1px solid var(--neon-green);
            padding: 8px 12px;
            border-radius: 4px;
            background: rgba(17, 26, 17, 0.8);
        }

        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .platform-modes {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }

        .mode-btn {
            background: var(--bg-color);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 12px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .mode-btn.active {
            border-color: var(--neon-green);
            box-shadow: 0 0 15px rgba(0, 230, 118, 0.4);
            color: var(--neon-green);
            background: var(--panel-color);
        }

        .grid-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 25px;
        }

        @media (max-width: 768px) {
            .grid-layout { grid-template-columns: 1fr; }
        }

        .card {
            background-color: var(--panel-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 24px;
            margin-bottom: 25px;
            position: relative;
            overflow: hidden;
        }

        .card h2 {
            color: var(--neon-green);
            margin: 0 0 10px 0;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
            font-size: 18px;
            letter-spacing: 1px;
        }

        /* 3D Kinetic Globe Layout Configurations */
        .globe-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px 0;
            background: radial-gradient(circle, rgba(0, 230, 118, 0.1) 0%, rgba(5,8,5,0) 70%);
            height: 220px;
            position: relative;
        }

        #globe-canvas-target {
            width: 100%;
            height: 100%;
            cursor: grab;
        }

        #globe-canvas-target:active {
            cursor: grabbing;
        }

        /* Dual Particle HUD Diagnostics Overlays */
        .hud-scanner {
            display: flex;
            gap: 15px;
            margin: 15px 0;
        }

        .hud-box {
            flex: 1;
            border: 2px solid var(--neon-green);
            border-radius: 6px;
            padding: 10px;
            font-family: monospace;
            font-size: 11px;
            background: rgba(0,0,0,0.4);
        }

        .hud-box.alert {
            border-color: var(--predator-red);
        }

        .btn-action {
            background-color: var(--neon-green);
            color: #050805;
            border: none;
            padding: 14px 20px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            margin-top: 15px;
            letter-spacing: 1px;
            transition: all 0.2s ease;
        }

        .btn-action:hover {
            box-shadow: 0 0 15px var(--neon-green);
            transform: translateY(-2px);
        }

        select, input, textarea {
            width: 100%;
            padding: 12px;
            background: #090f09;
            border: 1px solid var(--border-color);
            color: var(--neon-green);
            border-radius: 6px;
            box-sizing: border-box;
            margin-top: 8px;
            font-weight: 500;
        }

        select:focus, textarea:focus {
            outline: none;
            border-color: var(--neon-green);
        }

        .terminal-box {
            background: #000000;
            border: 1px solid var(--border-color);
            font-family: 'Courier New', Courier, monospace;
            padding: 18px;
            border-radius: 6px;
            color: #00FF66;
            min-height: 125px;
            max-height: 250px;
            overflow-y: auto;
            white-space: pre-line;
            line-height: 1.6;
        }

        /* Automated $MAZ Financial Wallet System */
        .token-counter {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0, 230, 118, 0.05);
            border: 1px solid var(--border-color);
            padding: 10px 15px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .token-val {
            color: var(--neon-green);
            font-weight: bold;
            font-size: 18px;
            text-shadow: 0 0 5px rgba(0,230,118,0.4);
        }

        /* Avatar Container Node Layout */
        .avatar-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            padding: 10px;
            border-radius: 8px;
            background: rgba(144, 164, 174, 0.05);
        }

        .avatar-graphics {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: 2px solid var(--neon-green);
            background: #111A11;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 22px;
            box-shadow: 0 0 10px var(--neon-green);
        }

        footer {
            text-align: center;
            padding: 40px;
            color: var(--text-main);
            font-size: 12px;
            border-top: 1px solid var(--border-color);
            margin-top: 50px;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-area">
            <h1>AgroApex
