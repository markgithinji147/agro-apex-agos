                    </select>

                    <div class="hud-scanner">
                        <div class="hud-box">
                            <span style="color: var(--neon-green)">[LENS MODE: 10X OPTICAL ZOOM]</span><br>
                            Spectral Field Array Matrix: ACTIVE<br>
                            Focus Lock: STABLE
                        </div>
                        <div class="hud-box alert">
                            <span style="color: var(--predator-red)">[DIAGNOSTIC SYSTEM SENSORS]</span><br>
                            Particle Scan Profile: RUNNING<br>
                            Anomaly Identifier Vector: SET
                        </div>
                    </div>

                    <button class="btn-action" onclick="runWebAI()">Trigger Predictive Research Engine</button>
                </div>

                <div id="sms-panel" class="card" style="display: none;">
                    <h2>Inbound Low-Bandwidth Gateway Controller</h2>
                    <p style="font-size: 13px; color: var(--text-main); margin-bottom: 20px;">Parses offline text packets into structured relational arrays without data requirements.</p>
                    
                    <label>Simulate Incoming User Raw Text String Payload:</label>
                    <textarea id="sms-text" rows="3">Tomato yellow spots in Kiambu</textarea>
                    
                    <button class="btn-action" onclick="runSMSAI()">Parse Text Packet & Dispatch Gateway Response</button>
                </div>

                <div class="card">
                    <h2>Central System Response Ledger (Verified Output Array)</h2>
                    <div id="terminal-output" class="terminal-box">
                        System pipeline initialized. Master Admin validation verified: Mark Githinji Karegu. Launch an operation module to populate arrays...
                    </div>
                </div>

            </div>

            <div class="sidebar-ledger">
                <div class="card">
                    <h2>Conservation Token Vault</h2>
                    <p style="font-size: 12px; color: var(--text-main); margin-bottom: 12px;">Financial ledger balance derived from verified plastic removal metrics.</p>
                    <div class="token-counter">
                        <span style="font-size: 13px; font-weight: bold; letter-spacing: 0.5px;">$MAZ TOKEN BALANCE</span>
                        <span class="token-val" id="token-display">1250 MAZ</span>
                    </div>
                </div>

                <div class="card">
                    <h2>Global Nexus Mapping</h2>
                    <p style="font-size: 12px; color: var(--text-main); margin-bottom: 15px;">Real-time asset tracking nodes locating production clusters instantly.</p>
                    <div class="globe-wrapper">
                        <div class="tech-globe"></div>
                    </div>
                </div>

                <div class="card">
                    <h2>Direct Market Ledger Connection</h2>
                    <table style="width: 100%; border-collapse: collapse; font-size: 13px; text-align: left; margin-top: 5px;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--border-color); color: var(--neon-green);">
                                <th style="padding-bottom: 8px;">Commodity</th>
                                <th style="padding-bottom: 8px;">Regional Hub</th>
                                <th style="padding-bottom: 8px;">Value Index</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom: 1px solid #142214;">
                                <td style="padding: 10px 0; color: white;">Maize (90KG)</td>
                                <td>Eldoret Hub</td>
                                <td style="color: var(--neon-green)">3,200 KES</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #142214;">
                                <td style="padding: 10px 0; color: white;">Tomatoes (Box)</td>
                                <td>Kiambu Hub</td>
                                <td style="color: var(--neon-green)">4,500 KES</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #142214;">
                                <td style="padding: 10px 0; color: white;">Potatoes (Bag)</td>
                                <td>Molo Hub</td>
                                <td style="color: var(--neon-green)">2,800 KES</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <footer>
        PROPRIETARY CORE SCHEMATIC ARCHITECTURE &bull; DESIGNED BY MARK GITHINJI KAREGU &bull; &copy; 2026 MARKAPEX TECHNOLOGIES
    </footer>

    <script>
        let currentTokens = 1250;

        function switchView(mode) {
            const webPanel = document.getElementById('web-panel');
            const smsPanel = document.getElementById('sms-panel');
            const btns = document.querySelectorAll('.mode-btn');
            
            btns.forEach(btn => btn.classList.remove('active'));
            
            if (mode === 'web') {
                webPanel.style.display = 'block';
                smsPanel.style.display = 'none';
                btns[0].classList.add('active');
            } else {
                webPanel.style.display = 'none';
                smsPanel.style.display = 'block';
                btns[1].classList.add('active');
            }
        }

        function runWebAI() {
            const selection = document.getElementById('crop-issue').value;
            const lang = document.getElementById('lang-select').value;
            const terminal = document.getElementById('terminal-output');
            const tokenBox = document.getElementById('token-display');
            
            let output = "";
            if (lang === 'sw') {
                if(selection === 'blight') {
                    output = "[LOGU YA APEX AI BRAIN]: Utambuzi: Baka la Mapema (Early Blight). Suluhisho: Tumia dawa ya ukungu ya shaba kuzuia uharibifu wa majani. Wavuni zao katika siku 14 zijazo kwa sababu ya ukavu unaokuja.";
                } else if(selection === 'plastic') {
                    output = "[ALAMU YA APEX HUD]: MFUMO UMEGUNDUA MICRO-PLASTIC KATIKA UCHANGANUZI WA UCHAFUZI! \n\nHatua: Safisha eneo lililoathiriwa. Zawadi ya Mazingira imetolewa: +150 $MAZ tokens zimeongezwa kwenye mkoba wako kwa hatua hii ya uhifadhi.";
                    currentTokens += 150;
                } else {
                    output = "[LOGU YA APEX AI BRAIN]: Shamba lina afya nzuri kabisa. Viwango vya nitrojeni na unyevu vipo salama.";
                }
            } else {
                if(selection === 'blight') {
                    output = "[APEX AI BRAIN LOG]: Diagnosis Verified: Early Blight detected via image signature indexing. Resolution: Apply copper-based formulation to leaf system immediately. Adaptive weather metrics update: Harvest inside 14 dry-window tracking days.";
                } else if(selection === 'plastic') {
                    output = "[CRITICAL DETECTOR ALERT]: SYNTHETIC MICRO-PLASTIC PARTICLES IDENTIFIED VIA HUD SCANNER CONTROLS! \n\nRemediation Protocol: Execute removal procedures immediately. Ecological bonus issued: +150 $MAZ credits deposited to vault for automated conservation contribution tracking.";
                    currentTokens += 150;
                } else {
                    output = "[APEX AI BRAIN LOG]: Matrix scan verified healthy crop profile canopy. Core structural metrics processing optimal.";
                }
            }
            terminal.innerText = output;
            tokenBox.innerText = currentTokens + " MAZ";
        }

        function runSMSAI() {
            const txt = document.getElementById('sms-text').value.toLowerCase();
            const terminal = document.getElementById('terminal-output');
            
            let output = "APEX SMS GATEWAY DATA DESERIALIZER OUTPUT:\n----------------------------------------\n";
            if (txt.includes('tomato') || txt.includes('spots')) {
                output += "Target Target: Tomatoes\nDiagnostic Parse: Early Blight Detected\nAction Logic: Spray Copper Fungicide\nKiambu Hub Integrated Market Index: 4,500 KES/Box\nStatus: Message payload compressed and optimized for feature network delivery.";
            } else if (txt.includes('maize') || txt.includes('corn')) {
                output += "Target Target: Maize Crop Profile\nDiagnostic Parse: Insect structural activity indicator logged\nAction Logic: Balance soil moisture content arrays\nEldoret Hub Integrated Market Index: 3,200 KES/Bag";
            } else {
                output += "System payload evaluated. Structural relational tracking match found. Target parameters forwarded to nearest processing database successfully.";
            }
            terminal.innerText = output;
        }

        function updateLanguage() {
            const lang = document.getElementById('lang-select').value;
            const terminal = document.getElementById('terminal-output');
            if (lang === 'sw') {
                terminal.innerText = "Mfumo upo tayari kufanya kazi. Msimamizi Mkuu amethibitishwa: Mark Githinji Karegu. Chagua operesheni hapo juu ili kuanzisha mtiririko wa data...";
            } else {
                terminal.innerText = "System pipeline initialized. Master Admin validation verified: Mark Githinji Karegu. Launch an operation module to populate arrays...";
            }
        }
    </script>
</body>
</html>
